<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Identity -->
    <key>CFBundleDevelopmentRegion</key>
    <string>tr</string>
    <key>CFBundleDisplayName</key>
    <string>WJ Diag</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- iOS Version -->
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>MinimumOSVersion</key>
    <string>16.0</string>

    <!-- UI -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UIRequiresFullScreen</key>
    <true/>
    <key>UIStatusBarHidden</key>
    <false/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- Ekran acik tut (araba kullanirken) -->
    <key>UIIdleTimerDisabled</key>
    <true/>

    <!-- === BLUETOOTH === -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>ELM327 OBD-II arac teshis cihazina Bluetooth ile baglanmak icin gereklidir</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>ELM327 OBD-II arac teshis cihazina baglanmak icin Bluetooth gereklidir</string>

    <!-- === WIFI / LOCAL NETWORK === -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>WiFi ELM327 OBD-II cihazina yerel ag uzerinden baglanmak icin gereklidir</string>

    <!-- Bonjour servisleri (Qt network icin) -->
    <key>NSBonjourServices</key>
    <array>
        <string>_tcp._tcp.</string>
    </array>

    <!-- === APP TRANSPORT SECURITY === -->
    <!-- WiFi ELM327 HTTP degil raw TCP kullanir, ATS kısıtlaması yok -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- === BACKGROUND MODES === -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-central</string>
    </array>
</dict>
</plist>
